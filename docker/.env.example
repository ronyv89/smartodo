# ============================================================
# smarTODO — Docker Compose environment variables
# cp .env.example .env  and fill in your values
#
# Loaded automatically by: docker compose -f docker/docker-compose.yml up
# ============================================================

# ── Postgres ─────────────────────────────────────────────────
POSTGRES_PASSWORD=postgres

# ── Supabase JWT / Keys ───────────────────────────────────────
# Must match supabase/config.toml → jwt_secret
SUPABASE_JWT_SECRET=super-secret-jwt-token-for-local-dev-only

# Anonymous (public) API key — get from `supabase status`
SUPABASE_ANON_KEY=

# Service role key — SERVER-SIDE ONLY
SUPABASE_SERVICE_ROLE_KEY=

# ── App URLs ──────────────────────────────────────────────────
# Kong gateway exposed on the host (browser / Next.js points here)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── AI (optional) ─────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Misc ──────────────────────────────────────────────────────
APP_VERSION=dev
