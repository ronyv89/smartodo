# ============================================================
# smarTODO — Root-level environment variables
# Used by: Jest integration tests (run from repo root)
# cp .env.local.example .env.local
#
# For the Next.js dev server use apps/web/.env.local.example
# For Docker Compose         use docker/.env.example
# ============================================================

# ──────────────────────────────────────────────────────────────
# Supabase (local dev via `supabase start` or docker-compose)
# ──────────────────────────────────────────────────────────────

# Public URL of your Supabase instance (exposed via Kong)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321

# Anonymous (public) API key — safe to expose in the browser
# Get from `supabase status` or Supabase dashboard
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SERVER-SIDE ONLY, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# JWT secret used to sign tokens (must match supabase config)
SUPABASE_JWT_SECRET=super-secret-jwt-token-for-local-dev-only

# ──────────────────────────────────────────────────────────────
# App
# ──────────────────────────────────────────────────────────────

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: shown in /api/health response (set in CI/CD to the git SHA or semver)
NEXT_PUBLIC_APP_VERSION=dev

# ──────────────────────────────────────────────────────────────
# AI (Pro tier only)
# ──────────────────────────────────────────────────────────────

# OpenRouter API key — required for Pro AI features
# Get from https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Model to use via OpenRouter (default: anthropic/claude-sonnet-4-5)
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# Master switch for AI features (default: true when OPENROUTER_API_KEY is set)
AI_FEATURES_ENABLED=true

# Disable Supabase Storage file attachments (default: true)
NEXT_PUBLIC_ATTACHMENTS_ENABLED=true

# Disable Supabase Realtime subscriptions (default: true)
NEXT_PUBLIC_REALTIME_ENABLED=true

# ──────────────────────────────────────────────────────────────
# Database (direct connection — integration tests only)
# ──────────────────────────────────────────────────────────────

DATABASE_URL=postgresql://postgres:postgres@localhost:54399/smartodo
