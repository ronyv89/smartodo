# ============================================================
# smarTODO — Next.js app environment variables
# cp .env.local.example .env.local  and fill in your values
# ============================================================

# ── Supabase ──────────────────────────────────────────────────
# URL of your Supabase instance (Kong gateway); get from `supabase status`
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321

# Anonymous (public) API key — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SERVER-SIDE ONLY, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# JWT secret — must match supabase/config.toml → jwt_secret
SUPABASE_JWT_SECRET=super-secret-jwt-token-for-local-dev-only

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Shown in /api/health; set to git SHA or semver in CI/CD
NEXT_PUBLIC_APP_VERSION=dev

# ── AI (Pro tier only) ────────────────────────────────────────
# Anthropic API key — required for AI features; get from https://console.anthropic.com
ANTHROPIC_API_KEY=

# Master switch for AI features (default: true when ANTHROPIC_API_KEY is set)
AI_FEATURES_ENABLED=true

# ── Feature flags ─────────────────────────────────────────────
NEXT_PUBLIC_ATTACHMENTS_ENABLED=true
NEXT_PUBLIC_REALTIME_ENABLED=true
