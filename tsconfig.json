{
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "exactOptionalPropertyTypes": true,
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "jsx": "preserve",
    "incremental": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@smartodo/core": ["./packages/core/src"],
      "@smartodo/core/*": ["./packages/core/src/*"],
      "@smartodo/ui": ["./packages/ui/src"],
      "@smartodo/ui/*": ["./packages/ui/src/*"],
      "@smartodo/plugin-sdk": ["./packages/plugin-sdk/src"],
      "@smartodo/plugin-sdk/*": ["./packages/plugin-sdk/src/*"],
      "@smartodo/ai": ["./packages/ai/src"],
      "@smartodo/ai/*": ["./packages/ai/src/*"],
      "@smartodo/supabase": ["./packages/supabase/src"],
      "@smartodo/supabase/*": ["./packages/supabase/src/*"],
      "@/*": ["./apps/web/src/*"]
    }
  },
  "exclude": ["node_modules"]
}
